# Copie para .env e ajuste conforme seu PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cinepajeu
# Se bruno não tiver CREATEDB, rode: sudo -u postgres psql -f scripts/create-database.sql
DB_USERNAME=bruno
DB_PASSWORD=sua_senha_aqui

JWT_SECRET=altere-em-producao

# URL pública do frontend (links de recuperação de senha)
FRONTEND_URL=http://localhost:3000

# Login social — mesmo Client ID / App ID do frontend
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# E-mail (SMTP) — opcional em dev; sem SMTP o link aparece no log da API
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@cinesaojose.com
